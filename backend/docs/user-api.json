{
    "openapi":"3.1.1",
    "info": {
      "title":"user-api",
      "version":"1.0"
    },
    "servers": [
      {"url":"https://localhost:8000"}
    ],
    "paths": {
        "/api/users": {
            "post": {
                "description": "Register user baru",
                "requestBody": {
                    "description": "Register user baru",
                    "content": {
                        "application/json": {
                            "examples": {
                                "azka": {
                                    "description": "Register user azka",
                                    "value": {
                                        "username": "azkazafran78",
                                        "email": "zafran734@gmail.com",
                                        "password": "newpelajar77"
                                    }
                                }
                            },
                            "schema": {
                                "type": "object",
                                "required": [
                                    "username", "email", "password"
                                ],
                                "properties": {
                                    "username": {
                                        "type": "string"
                                    },
                                    "email": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Sukses register user baru",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "sukses": {
                                        "description": "Sukses register user azka",
                                        "value": {
                                            "data": {
                                                "id": 1,
                                                "username": "azkazafran78",
                                                "email": "zafran734@gmail.com"
                                            },
                                            "errors": {}
                                        }
                                    }
                                },
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "id": {
                                                    "type": "number"
                                                },
                                                "username": {
                                                    "type": "string"
                                                },
                                                "email": {
                                                    "type": "string"
                                                }
                                            }
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Gagal register user baru",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "errorvalidation": {
                                        "description": "Error validation",
                                        "value": {
                                            "errors": {
                                                "username": [
                                                    "username tidak boleh kosong",
                                                    "username minimal 6 karakter"
                                                ],
                                                "email": [
                                                    "email tidak boleh kosong",
                                                    "email harus memiliki format email yang valid"
                                                ],
                                                "password": [
                                                    "password tidak boleh kosong",
                                                    "password minimal 12 karakter"
                                                ]
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/users/login": {
            "post": {
                "description": "Login user",
                "requestBody": {
                    "description": "Login user",
                    "content": {
                        "application/json": {
                            "examples": {
                                "azka": {
                                    "description": "Login user azka",
                                    "value": {
                                        "username": "azkazafran78",
                                        "password": "newpelajar77"
                                    }
                                }
                            },
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "username": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "202": {
                        "description": "Sukses login user",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "sukses": {
                                        "description": "Sukses login user azka",
                                        "value": {
                                            "data": {
                                                "id": 1,
                                                "username": "azkazafran78",
                                                "email": "zafran734@gmail.com",
                                                "token": "user-token-auth"
                                            },
                                            "errors": {}
                                        }
                                    }
                                },
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "id": {
                                                    "type": "number"
                                                },
                                                "username": {
                                                    "type": "string"
                                                },
                                                "email": {
                                                    "type": "string"
                                                },
                                                "token": {
                                                    "type": "string"
                                                }
                                            }
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "402": {
                        "description": "Gagal login user",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "wrongusernameorpassword": {
                                        "description": "Gagal login user azka",
                                        "value": {
                                            "errors": {
                                                "username": [
                                                    "username atau password salah"
                                                ],
                                                "password": [
                                                    "username atau password salah"
                                                ]
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/users/current": {
            "get": {
                "description": "Get user saat ini",
                "parameters": [
                    {
                        "name": "Authorization",
                        "in": "header",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "203": {
                        "description": "Sukses get user saat ini",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "sukses get": {
                                        "description": "Sukses get user saat ini",
                                        "value": {
                                            "data": {
                                                "id": 1,
                                                "username": "azkazafran78",
                                                "email": "zafran734@gmail.com"
                                            },
                                            "errors": {}
                                        }
                                    }
                                },
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "id": {
                                                    "type": "number"
                                                },
                                                "username": {
                                                    "type": "string"
                                                },
                                                "email": {
                                                    "type": "string"
                                                }
                                            }
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/users/logout": {
            "delete": {
                "description": "Logout user"
            }
        }
    }
  }