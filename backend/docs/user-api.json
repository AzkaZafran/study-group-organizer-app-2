{
    "openapi":"3.1.1",
    "info": {
      "title":"user-api",
      "version":"1.0"
    },
    "servers": [
      {"url":"https://localhost:8000"}
    ],
    "paths": {
        "/api/users": {
            "post": {
                "description": "Register user baru",
                "requestBody": {
                    "description": "Register user baru",
                    "content": {
                        "application/json": {
                            "examples": {
                                "azka": {
                                    "description": "Register user azka",
                                    "value": {
                                        "username": "azkazafran78",
                                        "email": "zafran734@gmail.com",
                                        "password": "newpelajar77"
                                    }
                                }
                            },
                            "schema": {
                                "type": "object",
                                "required": [
                                    "username", "email", "password"
                                ],
                                "properties": {
                                    "username": {
                                        "type": "string"
                                    },
                                    "email": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Sukses register user baru",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "sukses": {
                                        "description": "Sukses register user azka",
                                        "value": {
                                            "data": {
                                                "id": 1,
                                                "username": "azkazafran78",
                                                "email": "zafran734@gmail.com"
                                            },
                                            "errors": {}
                                        }
                                    }
                                },
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "id": {
                                                    "type": "number"
                                                },
                                                "username": {
                                                    "type": "string"
                                                },
                                                "email": {
                                                    "type": "string"
                                                }
                                            }
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Gagal register user baru",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "errorvalidation": {
                                        "description": "Error validation",
                                        "value": {
                                            "errors": {
                                                "username": [
                                                    "username tidak boleh kosong",
                                                    "username minimal 6 karakter"
                                                ],
                                                "email": [
                                                    "email tidak boleh kosong",
                                                    "email harus memiliki format email yang valid"
                                                ],
                                                "password": [
                                                    "password tidak boleh kosong",
                                                    "password minimal 12 karakter"
                                                ]
                                            }
                                        }
                                    },
                                    "usernameAlreadyExist": {
                                        "description": "Username already exist",
                                        "value": {
                                            "errors": {
                                                "message": "Username sudah dipakai."
                                            }
                                        }
                                    },
                                    "emailAlreadyExist": {
                                        "description": "Email already exist",
                                        "value": {
                                            "errors": {
                                                "message": "Email sudah dipakai."
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/users/request-otp": {
            "post": {
                "description": "Mengirim kode otp melalui email user",
                "requestBody": {
                    "description": "Mengirim kode otp melalui email user",
                    "content": {
                        "application/json": {
                            "examples": {
                                "azka": {
                                    "description": "Mengirim kode otp ke email azka",
                                    "value": {
                                        "email": "zafran734@gmail.com"
                                    }
                                }
                            },
                            "schema": {
                                "type": "object",
                                "required": [
                                    "email"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Sukses mengirim kode otp",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "boolean"
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }                
            }
        },
        "/api/users/verify-email": {
            "patch": {
                "description": "Verifikasi email user menggunakan kode otp",
                "requestBody": {
                    "description": "Verifikasi email user menggunakan kode otp",
                    "content": {
                        "application/json": {
                            "examples": {
                                "azka": {
                                    "description": "Verifikasi email azka",
                                    "value": {
                                        "email": "zafran734@gmail.com",
                                        "otp_code": "123456"
                                    }
                                }
                            },
                            "schema": {
                                "type": "object",
                                "required": [
                                    "email", "otp_code"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string"
                                    },
                                    "otp_code": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Sukses verifikasi email user",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "boolean"
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error - Invalid OTP",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "errors": {
                                            "type": "object",
                                            "properties": {
                                                "message": {
                                                    "type": "string",
                                                    "example": "kode OTP yang diberikan salah."
                                                }
                                            }
                                        }
                                    }
                                },
                                "examples": {
                                    "invalidOtp": {
                                        "description": "Kode OTP salah",
                                        "value": {
                                            "errors": {
                                                "message": "kode OTP yang diberikan salah."
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "410": {
                        "description": "Gone - OTP has expired",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "errors": {
                                            "type": "object",
                                            "properties": {
                                                "message": {
                                                    "type": "string",
                                                    "example": "Kode OTP ini sudah kadaluarsa. Mohon minta kode OTP yang baru."
                                                }
                                            }
                                        }
                                    }
                                },
                                "examples": {
                                    "expiredOtp": {
                                        "description": "Kode OTP sudah kadaluarsa",
                                        "value": {
                                            "errors": {
                                                "message": "Kode OTP ini sudah kadaluarsa. Mohon minta kode OTP yang baru."
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/users/login": {
            "post": {
                "description": "Login user",
                "requestBody": {
                    "description": "Login user",
                    "content": {
                        "application/json": {
                            "examples": {
                                "azka": {
                                    "description": "Login user azka",
                                    "value": {
                                        "username": "azkazafran78",
                                        "password": "newpelajar77"
                                    }
                                }
                            },
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "username": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Sukses login user",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "sukses": {
                                        "description": "Sukses login user azka",
                                        "value": {
                                            "data": {
                                                "id": 1,
                                                "username": "azkazafran78",
                                                "email": "zafran734@gmail.com",
                                                "token": "user-token-auth"
                                            },
                                            "errors": {}
                                        }
                                    }
                                },
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "id": {
                                                    "type": "number"
                                                },
                                                "username": {
                                                    "type": "string"
                                                },
                                                "email": {
                                                    "type": "string"
                                                },
                                                "token": {
                                                    "type": "string"
                                                }
                                            }
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Gagal login user",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "wrongusernameorpassword": {
                                        "description": "Gagal login user azka",
                                        "value": {
                                            "errors": {
                                                "message": "Username atau password salah."
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Gagal login user",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "errorvalidation": {
                                        "description": "Error validation",
                                        "value": {
                                            "errors": {
                                                "username": [
                                                    "Username tidak boleh kosong."
                                                ],
                                                "password": [
                                                    "Password tidak boleh kosong."
                                                ]
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/users/current": {
            "get": {
                "description": "Get user saat ini",
                "parameters": [
                    {
                        "name": "Authorization",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Sukses get user saat ini",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "sukses get": {
                                        "description": "Sukses get user saat ini",
                                        "value": {
                                            "data": {
                                                "id": 1,
                                                "username": "azkazafran78",
                                                "email": "zafran734@gmail.com"
                                            },
                                            "errors": {}
                                        }
                                    }
                                },
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "id": {
                                                    "type": "number"
                                                },
                                                "username": {
                                                    "type": "string"
                                                },
                                                "email": {
                                                    "type": "string"
                                                }
                                            }
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - Token invalid or missing",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "errors": {
                                            "type": "object",
                                            "properties": {
                                                "message": {
                                                "type": "string",
                                                "example": "Unauthorized"
                                                }
                                            }
                                        }
                                    }
                                },
                                "examples": {
                                    "missingToken": {
                                        "summary": "Token tidak dikirim",
                                        "value": {
                                            "errors": {
                                                "message": "Authorization token is required."
                                            }
                                        }
                                    },
                                    "invalidToken": {
                                        "summary": "Token tidak valid",
                                        "value": {
                                            "errors": {
                                                "message": "Invalid token."
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/users/logout": {
            "delete": {
                "description": "Logout user",
                "parameters": [
                    {
                        "name": "Authorization",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Sukses logout user",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "boolean"
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - Token invalid or missing",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "errors": {
                                            "type": "object",
                                            "properties": {
                                                "message": {
                                                "type": "string",
                                                "example": "Unauthorized"
                                                }
                                            }
                                        }
                                    }
                                },
                                "examples": {
                                    "missingToken": {
                                        "summary": "Token tidak dikirim",
                                        "value": {
                                            "errors": {
                                                "message": "Authorization token is required."
                                            }
                                        }
                                    },
                                    "invalidToken": {
                                        "summary": "Token tidak valid",
                                        "value": {
                                            "errors": {
                                                "message": "Invalid token."
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/users/search": {
            "get": {
                "description": "Mencari data user yang sesuai dengan input username",
                "parameters": [
                    {
                        "name": "Authorization",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "username",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "size",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "number"
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "number"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Proses query berhasil",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "userFound": {
                                        "description": "Sukses menemukan user yang dicari",
                                        "value": {
                                            "data": [
                                                {
                                                    "id": 7,
                                                    "username": "pelajar#40"
                                                },
                                                {
                                                    "id": 5,
                                                    "username": "pelajar#39"
                                                }
                                            ],
                                            "errors": {},
                                            "meta": {
                                                "page": 1
                                            }
                                        }
                                    },
                                    "userNotFound": {
                                        "description": "Tidak dapat menemukan user yang sesuai dengan kata kunci yang diberikan",
                                        "value": {
                                            "data": [],
                                            "errors": {},
                                            "meta": {
                                                "pages": 0,
                                                "message": "Tidak dapat menemukan user yang sesuai"
                                            }
                                        }
                                    },
                                    "blankQuery": {
                                        "description": "Kata kunci yang diberikan kosong",
                                        "value": {
                                            "data": [],
                                            "errors": {},
                                            "meta": {
                                                "pages": 0,
                                                "message": "Tidak dapat menemukan user yang sesuai"
                                            }
                                        }
                                    }
                                },
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "id": {
                                                        "type": "number"
                                                    },
                                                    "username": {
                                                        "type": "string"
                                                    }
                                                }
                                            }
                                        },
                                        "errors": {
                                            "type": "object"
                                        },
                                        "meta": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - Token invalid or missing",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "errors": {
                                            "type": "object",
                                            "properties": {
                                                "message": {
                                                "type": "string",
                                                "example": "Unauthorized"
                                                }
                                            }
                                        }
                                    }
                                },
                                "examples": {
                                    "missingToken": {
                                        "summary": "Token tidak dikirim",
                                        "value": {
                                            "errors": {
                                                "message": "Authorization token is required."
                                            }
                                        }
                                    },
                                    "invalidToken": {
                                        "summary": "Token tidak valid",
                                        "value": {
                                            "errors": {
                                                "message": "Invalid token."
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
  }