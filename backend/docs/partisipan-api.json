{
    "openapi":"3.1.1",
    "info": {
      "title":"partisipan-api",
      "version":"1.0"
    },
    "servers": [
      {"url":"https://localhost:8000"}
    ],
    "paths": {
        "/api/agenda/{id_agenda}/partisipan": {
            "get": {
                "description": "Mengambil data partisipan dalam agenda",
                "parameters": [
                    {
                        "name": "Authorization",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "id_agenda",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "number"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Berhasil mengambil data partisipan agenda",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "sukses": {
                                        "description": "Berhasil mengambil data partisipan suatu agenda",
                                        "value": {
                                            "data": [
                                                {
                                                    "id": 1,
                                                    "username": "azkazafran78",
                                                    "email": "zafran734@gmail.com",
                                                    "role": "penyelenggara"
                                                },
                                                {
                                                    "id": 5,
                                                    "username": "pelajar#39",
                                                    "email": "pelajar39@email.com",
                                                    "role": "anggota"
                                                }
                                            ],
                                            "errors": {}
                                        }
                                    }
                                },
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "id": {
                                                        "type": "number"
                                                    },
                                                    "username": {
                                                        "type": "string"
                                                    },
                                                    "email": {
                                                        "type": "string"
                                                    },
                                                    "role": {
                                                        "type": "string"
                                                    }
                                                }
                                            }
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found - Agenda tidak dapat ditemukan",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "errors": {
                                            "type": "object",
                                            "properties": {
                                                "message": {
                                                    "type": "string",
                                                    "example": "Agenda yang dicari tidak ada dalam database."
                                                }
                                            }
                                        }
                                    }
                                },
                                "examples": {
                                    "agendaNotFound": {
                                        "description": "Agenda tidak dapat ditemukan",
                                        "value": {
                                            "errors": {
                                                "message": "Agenda yang dicari tidak ada dalam database."
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - Token invalid or missing",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "errors": {
                                            "type": "object",
                                            "properties": {
                                                "message": {
                                                "type": "string",
                                                "example": "Unauthorized"
                                                }
                                            }
                                        }
                                    }
                                },
                                "examples": {
                                    "missingToken": {
                                        "summary": "Token tidak dikirim",
                                        "value": {
                                            "errors": {
                                                "message": "Authorization token is required."
                                            }
                                        }
                                    },
                                    "invalidToken": {
                                        "summary": "Token tidak valid",
                                        "value": {
                                            "errors": {
                                                "message": "Invalid token."
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "Membuat data partisipan agenda",
                "parameters": [
                    {
                        "name": "Authorization",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "id_agenda",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "number"
                        }
                    }
                ],
                "requestBody": {
                    "description": "Membuat data partisipan agenda",
                    "content": {
                        "application/json": {
                            "examples": {
                                "partisipanBelajarBareng": {
                                    "description": "Membuat data partisipan agenda belajar bareng",
                                    "value": {
                                        "ids": [2, 4, 7]
                                    }
                                }
                            },
                            "schema": {
                                "type": "object",
                                "required": [
                                    "ids"
                                ],
                                "properties": {
                                    "ids": {
                                        "type": "array",
                                        "items": {
                                            "type": "number"
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Berhasil membuat data partisipan agenda",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "boolean"
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found - Agenda tidak dapat ditemukan",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "errors": {
                                            "type": "object",
                                            "properties": {
                                                "message": {
                                                    "type": "string",
                                                    "example": "Agenda yang dicari tidak ada dalam database."
                                                }
                                            }
                                        }
                                    }
                                },
                                "examples": {
                                    "agendaNotFound": {
                                        "description": "Agenda tidak dapat ditemukan",
                                        "value": {
                                            "errors": {
                                                "message": "Agenda yang dicari tidak ada dalam database."
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - Token invalid or missing",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "errors": {
                                            "type": "object",
                                            "properties": {
                                                "message": {
                                                "type": "string",
                                                "example": "Unauthorized"
                                                }
                                            }
                                        }
                                    }
                                },
                                "examples": {
                                    "missingToken": {
                                        "summary": "Token tidak dikirim",
                                        "value": {
                                            "errors": {
                                                "message": "Authorization token is required."
                                            }
                                        }
                                    },
                                    "invalidToken": {
                                        "summary": "Token tidak valid",
                                        "value": {
                                            "errors": {
                                                "message": "Invalid token."
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
  }