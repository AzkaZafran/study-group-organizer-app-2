{
    "openapi":"3.1.1",
    "info": {
      "title":"friend-api",
      "version":"1.0"
    },
    "servers": [
      {"url":"https://localhost:8000"}
    ],
    "paths": {
        "/api/users/friends/request": {
            "post": {
                "description": "User meminta pertemanan kepada user lain",
                "parameters": [
                    {
                        "name": "Authorization",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "description": "User meminta pertemanan kepada user lain",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "id"
                                ],
                                "properties": {
                                    "id": {
                                        "type": "number"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Berhasil mengirim dan membuat data permintaan teman",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "boolean"
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found - User tidak dapat ditemukan",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "errors": {
                                            "type": "object",
                                            "properties": {
                                                "message": {
                                                    "type": "string",
                                                    "example": "User yang dicari tidak ada dalam database."
                                                }
                                            }
                                        }
                                    }
                                },
                                "examples": {
                                    "userNotFound": {
                                        "description": "User tidak dapat ditemukan",
                                        "value": {
                                            "errors": {
                                                "message": "User yang dicari tidak ada dalam database."
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - Token invalid or missing",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "errors": {
                                            "type": "object",
                                            "properties": {
                                                "message": {
                                                "type": "string",
                                                "example": "Unauthorized"
                                                }
                                            }
                                        }
                                    }
                                },
                                "examples": {
                                    "missingToken": {
                                        "summary": "Token tidak dikirim",
                                        "value": {
                                            "errors": {
                                                "message": "Authorization token is required."
                                            }
                                        }
                                    },
                                    "invalidToken": {
                                        "summary": "Token tidak valid",
                                        "value": {
                                            "errors": {
                                                "message": "Invalid token."
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "get": {
                "description": "Mengambil data permintaan teman user yang belum di respon",
                "parameters": [
                    {
                        "name": "Authorization",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Sukses mengambil data permintaan teman user",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "sukses": {
                                        "description": "Sukses mengambil data permintaan teman user",
                                        "value": {
                                            "data": [
                                                {
                                                    "id_request": 7,
                                                    "username": "pelajar#40"
                                                },
                                                {
                                                    "id_request": 5,
                                                    "username": "pelajar#39"
                                                }
                                            ],
                                            "errors": {}
                                        }
                                    }
                                },
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "id_request": {
                                                        "type": "number"
                                                    },
                                                    "username": {
                                                        "type": "string"
                                                    }
                                                }
                                            }
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - Token invalid or missing",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "errors": {
                                            "type": "object",
                                            "properties": {
                                                "message": {
                                                "type": "string",
                                                "example": "Unauthorized"
                                                }
                                            }
                                        }
                                    }
                                },
                                "examples": {
                                    "missingToken": {
                                        "summary": "Token tidak dikirim",
                                        "value": {
                                            "errors": {
                                                "message": "Authorization token is required."
                                            }
                                        }
                                    },
                                    "invalidToken": {
                                        "summary": "Token tidak valid",
                                        "value": {
                                            "errors": {
                                                "message": "Invalid token."
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
