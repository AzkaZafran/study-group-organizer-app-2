        "/api/users/friends": {
            "get": {
                "description": "Mengambil data teman user",
                "parameters": [
                    {
                        "name": "Authorization",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Sukses mengambil data teman user",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "sukses": {
                                        "description": "Sukses mengambil data teman user",
                                        "value": {
                                            "data": [
                                                {
                                                    "id": 7,
                                                    "username": "pelajar#40",
                                                    "email": "pelajar40@gmail.com"
                                                },
                                                {
                                                    "id": 5,
                                                    "username": "pelajar#39",
                                                    "email": "pelajar39@gmail.com"
                                                }
                                            ],
                                            "errors": {}
                                        }
                                    }
                                },
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "id": {
                                                        "type": "number"
                                                    },
                                                    "username": {
                                                        "type": "string"
                                                    },
                                                    "email": {
                                                        "type": "string"
                                                    }
                                                }
                                            }
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - Token invalid or missing",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "errors": {
                                            "type": "object",
                                            "properties": {
                                                "message": {
                                                "type": "string",
                                                "example": "Unauthorized"
                                                }
                                            }
                                        }
                                    }
                                },
                                "examples": {
                                    "missingToken": {
                                        "summary": "Token tidak dikirim",
                                        "value": {
                                            "errors": {
                                                "message": "Authorization token is required."
                                            }
                                        }
                                    },
                                    "invalidToken": {
                                        "summary": "Token tidak valid",
                                        "value": {
                                            "errors": {
                                                "message": "Invalid token."
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
